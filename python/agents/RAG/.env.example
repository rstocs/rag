# ============================================================
# Environment configuration for the Environmental Testing
# Report Q&A Agent
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# DO NOT commit .env — it contains credentials.
# ============================================================

# ── LLM backend ──────────────────────────────────────────────
# Set to 1 to use Vertex AI (required for Vertex AI RAG Engine).
# Set to 0 to use the ML Developer API (GOOGLE_API_KEY required).
GOOGLE_GENAI_USE_VERTEXAI=1

# Only needed when GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=YOUR_VALUE_HERE

# ── Google Cloud ─────────────────────────────────────────────
# Your GCP project ID (string, not number).
GOOGLE_CLOUD_PROJECT=your-project-id

# Region for Vertex AI RAG Engine and other services.
# Must be a real region — "global" is NOT supported for RAG.
# Example: us-west1, us-central1, europe-west1
GOOGLE_CLOUD_LOCATION=us-west1

# ── Storage ──────────────────────────────────────────────────
# GCS bucket used to stage the PDF before corpus import and to
# store vision-extracted text files.  Format: gs://bucket-name
# The bucket is created automatically if it does not exist.
STAGING_BUCKET=gs://your-bucket-name

# ── RAG corpus ───────────────────────────────────────────────
# Auto-populated by prepare_corpus_and_data.py.
# Format: projects/<project-number>/locations/<location>/ragCorpora/<id>
RAG_CORPUS=

# ── Deployment (optional) ────────────────────────────────────
# Only needed when testing a deployed Vertex AI Agent Engine instance.
# Auto-populated by deployment/deploy.py.
# Format: projects/<project-number>/locations/<location>/reasoningEngines/<id>
AGENT_ENGINE_ID=

# ── Arize Phoenix tracing (optional) ─────────────────────────
# Leave blank to disable tracing entirely.
#
# ARIZE_SPACE_ID must be the base64-encoded space ID found in your
# Arize account URL (e.g. app.arize.com/organizations/ORG/spaces/ID).
# Using a plain slug (e.g. "my-space") will cause StatusCode.INTERNAL
# errors from otlp.arize.com.
ARIZE_SPACE_ID=
ARIZE_API_KEY=
# Optional: display name for this project in the Arize UI (default: adk-rag-agent)
ARIZE_PROJECT_NAME=adk-rag-agent
